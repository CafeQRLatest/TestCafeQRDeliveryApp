# ─── Cafe QR Delivery App — Environment Variables ────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=https://cafe-qr-backend.onrender.com/api

# Set to 'true' when building the Android APK (enables static export)
NEXT_PUBLIC_NATIVE_BUILD=false

# JWT secret (server-side only — never expose to client)
JWT_SECRET=replace_with_a_long_random_secret
