# ─── Cafe QR Delivery App — Environment Variables ────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# Add ALL of these to the Vercel dashboard (Settings → Environment Variables)
# for the TestCafeQRDeliveryApp project under the CafeQRLatest account.

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the CafeQR Spring Boot backend (no trailing slash).
# Test: https://cafe-qr-backend.onrender.com/api
# Production: https://api.cafeqr.in/api
NEXT_PUBLIC_API_BASE_URL=https://cafe-qr-backend.onrender.com/api

# ── Session signing (server-side only — NEVER expose to client) ───────────────
# HMAC-SHA256 secret used by lib/auth.js to sign & verify delivery_session cookies.
# Must be a 64-character random hex string. Same value must be set in the
# backend Docker environment if the backend also validates it.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
INTERNAL_API_SECRET=replace_with_a_long_random_64_char_secret

# ── Firebase Client SDK (safe to expose — published in browser bundle) ────────
# All values from Firebase Console → Project Settings → Your Apps → Web App.
# Architecture doc Section 4.6
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# VAPID key from Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Firebase Admin SDK (SERVER-SIDE ONLY — NEVER expose to client) ────────────
# Service account JSON from Firebase Console → Project Settings → Service Accounts
# → Generate new private key. Paste the entire JSON as a single line (escape quotes).
# Used by any server-side API routes that send push notifications via Firebase Admin.
# Example: {"type":"service_account","project_id":"...", ...}
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=

# ── Gmail OAuth2 (server-side only — for OTP email sending) ──────────────────
# Used by pages/api/auth/send-otp.js to send OTP emails via Gmail API.
# One-time setup — see architecture doc Section 14 for step-by-step:
#   1. Google Cloud Console → APIs → Enable Gmail API
#   2. Create OAuth 2.0 Client ID (Web Application type)
#   3. Authorised redirect URI: https://developers.google.com/oauthplayground
#   4. OAuth Playground → Settings → Use your own credentials → enter Client ID & Secret
#   5. Authorize scope: https://mail.googleapis.com/auth/gmail.send
#   6. Exchange auth code → copy Refresh Token
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_ADDRESS=noreply@cafeqr.in

# ── App Config ────────────────────────────────────────────────────────────────
# Public app URL (used for canonical links, open graph, FCM click_action)
# Test Vercel URL or custom domain
NEXT_PUBLIC_APP_URL=https://cafe-delivery-app-test.vercel.app
NEXT_PUBLIC_APP_NAME=CafeQR Delivery
NEXT_PUBLIC_SUPPORT_PHONE=+919876543210

# ── Capacitor / Android build ─────────────────────────────────────────────────
# Set to 'true' when building the Android APK (enables Next.js static export).
# Leave 'false' (or unset) for PWA / web / Vercel deployment.
NEXT_PUBLIC_NATIVE_BUILD=false

# ── Environment flag ──────────────────────────────────────────────────────────
APP_ENV=development
